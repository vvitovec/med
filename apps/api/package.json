{
  "name": "@trust-coupons/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "worker": "tsx src/worker/run-worker.ts",
    "seed:coupons": "tsx src/seed/discovered-coupons.ts",
    "build": "tsc -p tsconfig.json",
