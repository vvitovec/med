    "@trust-coupons/shared": "file:../../packages/shared",
    "bullmq": "^5.49.0",
    "fastify": "^5.3.2",
    "ioredis": "^5.6.1",
    "pg": "^8.15.6",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.14",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
