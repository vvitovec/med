NODE_ENV=development
PUBLIC_API_BASE_URL=http://localhost:3100
PRODUCTION_API_BASE_URL=https://coupons-api.vvitovec.com

# Home-server production API listens on 127.0.0.1:3100 behind Cloudflare Tunnel.
API_HOST=0.0.0.0
API_PORT=3100

# Do not commit real secrets.
DATABASE_URL=postgres://trust_coupons_app:change-me@127.0.0.1:5432/trust_coupons
ADMIN_DATABASE_URL=postgres://trust_coupons_admin:change-me@127.0.0.1:5432/trust_coupons
REDIS_URL=redis://127.0.0.1:6380

ADMIN_SESSION_SECRET=change-me-at-least-32-chars
ADMIN_ACCESS_EMAIL_DOMAIN=vvitovec.com
CLOUDFLARE_ACCESS_JWT_AUD=

SUPABASE_URL=http://127.0.0.1:8000
SUPABASE_STORAGE_BUCKET=trust-coupons
SUPABASE_SERVICE_ROLE_KEY=

AFFILIATE_DISCLOSURE_URL=https://coupons-api.vvitovec.com/privacy
